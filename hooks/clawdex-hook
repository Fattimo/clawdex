#!/bin/sh
# clawdex-hook — translate Claude Code / Codex hook events to clawdex animation
# rows.
#
# Wired into ~/.claude/settings.json (Claude Code) or a Codex hooks.json /
# plugin. Reads the hook payload (JSON) on stdin, picks an animation row, and
# sends a one-line event to the clawdex daemon's Unix socket. Never blocks: any
# failure exits 0 silently so the agent never waits on the pet.
#
# Codex and Claude Code share a hook contract — same PascalCase event names
# (SessionStart/PreToolUse/PostToolUse/Stop/…), same stdin payload fields
# (hook_event_name, tool_name, cwd, transcript_path). The one divergence we
# care about: Codex fires `PermissionRequest` where Claude fires `Notification`.
#
# The ingesting agent is stamped onto every message so the daemon can label and
# color each agent's sessions distinctly. Defaults to "claude"; Codex wires it
# in as `clawdex-hook codex` (or CLAWDEX_AGENT=codex).
#
# Animation rows are defined by openai/skills hatch-pet (animation-rows.md):
#   0 idle  1 running-right  2 running-left  3 waving  4 jumping
#   5 failed  6 waiting  7 running  8 review

SOCK="${CLAWDEX_SOCK:-$HOME/.clawdex/sock}"
AGENT="${CLAWDEX_AGENT:-${1:-claude}}"

# Read all stdin (Claude Code passes the hook payload as JSON).
PAYLOAD="$(cat)"

# Tiny JSON field extractor. Avoids a jq dependency — clawdex must work on
# any user's machine. Pulls a top-level string field by name.
json_get() {
  printf '%s' "$PAYLOAD" \
    | tr -d '\n' \
    | sed -n 's/.*"'"$1"'"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p' \
    | head -n1
}

# Numeric/boolean field (best-effort — only used for tool_response.success-ish).
json_get_raw() {
  printf '%s' "$PAYLOAD" \
    | tr -d '\n' \
    | sed -n 's/.*"'"$1"'"[[:space:]]*:[[:space:]]*\([^,}]*\).*/\1/p' \
    | head -n1
}

basename_of() { printf '%s' "${1##*/}"; }

# Resolve the project root ("the root of it all"). Claude's cwd follows the
# agent's `cd`s, so it can be deep inside a repo (e.g. .../backend/go/src/pylon).
# Walk up to the nearest .git so the label + click-to-open target the repo root.
# Falls back to the original dir if it isn't in a repo.
find_root() {
  d="$1"
  while [ -n "$d" ] && [ "$d" != "/" ]; do
    [ -e "$d/.git" ] && { printf '%s' "$d"; return; }
    d="$(dirname "$d")"
  done
  printf '%s' "$1"
}

EVENT="$(json_get hook_event_name)"
TOOL="$(json_get tool_name)"
TRANSCRIPT="$(json_get transcript_path)"
# Project the event came from. CWD is the agent's live working dir; ROOT is the
# repo root we actually want to label by and open on click; SOURCE is its name.
CWD="$(json_get cwd)"
ROOT="$(find_root "$CWD")"
SOURCE="$(basename_of "$ROOT")"

# JSON-escape a string for embedding in our one-line message. No jq — pure
# sed/tr. Backslash first, then quote, then strip control chars.
json_escape() {
  printf '%s' "$1" \
    | sed 's/\\/\\\\/g; s/"/\\"/g' \
    | tr -d '\n\r\t'
}

# Same, but caps length first so a giant command can't blow up the bubble.
# Only for display narration — never for paths.
json_escape_short() {
  # Strip trailing backslashes (artifact of the quote-stopping extractor on
  # commands that contain a "), then cap length and escape.
  printf '%s' "$1" | sed 's/[[:space:]]*\\*$//' | cut -c1-80 | json_escape_stdin
}
json_escape_stdin() {
  sed 's/\\/\\\\/g; s/"/\\"/g' | tr -d '\n\r\t'
}

# State translation — see docs/state-mapping.md for rationale.
ROW=0
MODE=transient    # transient: play once, daemon returns to idle. sticky: hold.
TTL=0             # ms; 0 = use row's natural duration.

case "$EVENT" in
  SessionStart)
    ROW=3; MODE=transient ;;                    # waving — hello
  UserPromptSubmit)
    ROW=8; MODE=sticky; TTL=2000 ;;             # review — thinking
  PreToolUse)
    case "$TOOL" in
      Bash|Edit|Write|MultiEdit|NotebookEdit)
        ROW=7; MODE=sticky ;;                   # running — doing work
      Read|Grep|Glob|WebFetch|WebSearch)
        ROW=8; MODE=sticky ;;                   # review — searching/reading
      *)
        ROW=7; MODE=sticky ;;
    esac ;;
  PostToolUse)
    # Don't fight other state — let UserPromptSubmit's "review" or Stop's
    # "waving" take over. Send a soft "release sticky" hint.
    ROW=-1; MODE=release ;;
  Notification|PermissionRequest)
    # Claude fires Notification; Codex fires PermissionRequest. Same meaning.
    ROW=6; MODE=sticky ;;                       # waiting — permission prompt
  Stop|SubagentStop)
    # Use stop_hook_active to detect agent finishing without error.
    ROW=3; MODE=transient ;;                    # waving — done (success path)
  SessionEnd)
    ROW=0; MODE=release ;;                       # session closed — drop its pill
  PreCompact|PostCompact)
    ROW=8; MODE=sticky; TTL=1500 ;;             # review — compacting context
  *)
    exit 0 ;;
esac

# Action narration — a glanceable one-liner the daemon shows in the speech
# bubble when there's no fresher prose in the transcript (e.g. mid-tool-call).
# The daemon prefers Claude's real words; this fills the gaps.
NARRATION=""
case "$EVENT" in
  UserPromptSubmit)
    NARRATION="thinking…" ;;
  PreToolUse)
    case "$TOOL" in
      Bash)
        NARRATION="$(json_get command)" ;;
      Edit|Write|MultiEdit|NotebookEdit)
        NARRATION="Editing $(basename_of "$(json_get file_path)")" ;;
      Read)
        NARRATION="Reading $(basename_of "$(json_get file_path)")" ;;
      Grep)
        NARRATION="Searching $(json_get pattern)" ;;
      Glob)
        NARRATION="Finding $(json_get pattern)" ;;
      WebFetch)
        NARRATION="Fetching a page" ;;
      WebSearch)
        NARRATION="Searching the web" ;;
      Task)
        NARRATION="Running a subagent…" ;;
      *)
        NARRATION="$TOOL" ;;
    esac ;;
  Notification|PermissionRequest)
    NARRATION="waiting for you" ;;
  PreCompact|PostCompact)
    NARRATION="compacting…" ;;
  # SessionStart / Stop / SubagentStop: leave empty so the daemon shows the
  # latest real prose (the greeting / final answer) instead of a canned line.
esac

# Compose the daemon message. JSON line, easy to debug with `nc -lU`.
TS="$(date +%s)"
TEXT="$(json_escape_short "$NARRATION")"
TRANSCRIPT_ESC="$(json_escape "$TRANSCRIPT")"
SOURCE_ESC="$(json_escape_short "$SOURCE")"
ROOT_ESC="$(json_escape "$ROOT")"
MSG="{\"event\":\"$EVENT\",\"agent\":\"$AGENT\",\"tool\":\"$TOOL\",\"row\":$ROW,\"mode\":\"$MODE\",\"ttl\":$TTL,\"text\":\"$TEXT\",\"transcript\":\"$TRANSCRIPT_ESC\",\"source\":\"$SOURCE_ESC\",\"root\":\"$ROOT_ESC\",\"ts\":$TS}"

# Best-effort send. If the daemon isn't running, exit silently. Use a short
# timeout via the OS rather than nc flags (varies between BSD nc and ncat).
if [ -S "$SOCK" ]; then
  printf '%s\n' "$MSG" | nc -U "$SOCK" >/dev/null 2>&1 &
  # Reap in background; never wait. Detach so Claude Code doesn't block.
  disown 2>/dev/null || true
fi

# Trail log — first thing to check when "is the pet getting events?" comes up.
# Toggle off by setting CLAWDEX_NO_TRAIL=1 in your shell env.
if [ -z "$CLAWDEX_NO_TRAIL" ] && [ -d "$HOME/.clawdex" ]; then
  printf '%s %s\n' "$(date +%H:%M:%S)" "$MSG" >> "$HOME/.clawdex/hook-trail.log"
fi

exit 0
