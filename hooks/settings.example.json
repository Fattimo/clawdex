{
  "_comment": "Drop this into ~/.claude/settings.json (or merge with your existing config). Replace HOOKS_DIR with the install path printed by `clawdex install` — usually /usr/local/share/clawdex/hooks or ~/.clawdex/hooks.",

  "hooks": {
    "SessionStart":     [{ "hooks": [{ "type": "command", "command": "HOOKS_DIR/clawdex-hook" }] }],
    "UserPromptSubmit": [{ "hooks": [{ "type": "command", "command": "HOOKS_DIR/clawdex-hook" }] }],
    "PreToolUse":       [{ "hooks": [{ "type": "command", "command": "HOOKS_DIR/clawdex-hook" }] }],
    "PostToolUse":      [{ "hooks": [{ "type": "command", "command": "HOOKS_DIR/clawdex-hook" }] }],
    "Notification":     [{ "hooks": [{ "type": "command", "command": "HOOKS_DIR/clawdex-hook" }] }],
    "Stop":             [{ "hooks": [{ "type": "command", "command": "HOOKS_DIR/clawdex-hook" }] }],
    "SubagentStop":     [{ "hooks": [{ "type": "command", "command": "HOOKS_DIR/clawdex-hook" }] }],
    "PreCompact":       [{ "hooks": [{ "type": "command", "command": "HOOKS_DIR/clawdex-hook" }] }]
  },

  "statusLine": {
    "type": "command",
    "command": "HOOKS_DIR/clawdex-statusline"
  }
}
